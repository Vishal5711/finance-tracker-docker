# Production Environment Variables
MYSQL_ROOT_PASSWORD=secure_prod_password_123
MYSQL_DATABASE=finance_db
MYSQL_USER=finance_user
MYSQL_PASSWORD=secure_user_password_456

# Flask Configuration
FLASK_ENV=production
